# Meetily Web configuration — copy to .env and edit for your environment.
# Every external connection is configurable here; nothing is hardcoded.

# ---- Ports ----
BACKEND_PORT=5167
FRONTEND_PORT=3000

# ---- Frontend -> Backend ----
# URL the browser uses to reach the backend (baked into the frontend at build).
NEXT_PUBLIC_API_URL=http://localhost:5167

# ---- Transcription (external whisper.cpp HTTP server) ----
# The backend forwards browser audio to <WHISPER_SERVER_URL>/inference.
WHISPER_SERVER_URL=http://host.docker.internal:8178

# ---- Summarization LLM (external) ----
# provider: ollama | openai | groq | openrouter | anthropic
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2
LLM_API_KEY=

# ---- Summarization chunking ----
CHUNK_SIZE=5000
CHUNK_OVERLAP=1000
