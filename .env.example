# Meetily Web configuration — copy to .env and edit for your environment.
# Every external connection is configurable here; nothing is hardcoded.

# ---- Ports ----
BACKEND_PORT=5167
FRONTEND_PORT=3000

# ---- Frontend -> Backend ----
# URL the browser uses to reach the backend (baked into the frontend at build).
NEXT_PUBLIC_API_URL=http://localhost:5167

# ---- Transcription (external whisper.cpp HTTP server) ----
# The backend forwards browser audio to <WHISPER_SERVER_URL>/inference.
# IMPORTANT: for Hebrew, run the whisper server with a MULTILINGUAL model
# (e.g. ggml-large-v3.bin or ggml-medium.bin, NOT a *.en model).
WHISPER_SERVER_URL=http://host.docker.internal:8178
# Force transcription language (ISO code). Set to "he" for Hebrew; leave
# blank to auto-detect.
WHISPER_LANGUAGE=he

# ---- Speaker diarization (external WhisperX service) ----
# Post-meeting, full recordings are sent to <DIARIZE_SERVER_URL>/transcribe-diarize
# for speaker identification. See whisperx-service/README.md for setup.
DIARIZE_SERVER_URL=http://host.docker.internal:9000

# ---- Summarization LLM (external) ----
# provider: ollama | openai | groq | openrouter | anthropic
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=gemma4:26b
LLM_API_KEY=

# ---- Summarization chunking ----
CHUNK_SIZE=5000
CHUNK_OVERLAP=1000
